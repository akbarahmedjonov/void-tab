{
  "manifest_version": 3,
  "name": "void-tab",
  "version": "1.0.3",
  "description": "A minimal, privacy-focused startpage for your browser.",
  "chrome_settings_overrides": {
    "homepage": "index.html"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "void-tab@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["locationInfo"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": ["geolocation"],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://ip-api.com/*"
  ]
}
